# ── API Backend ───────────────────────────────────────────────────────────────
# Ces variables sont BAKED au build (pnpm build).
# Après tout changement, relancer : pnpm build && pnpm start

# Dev local :
# NEXT_PUBLIC_API_URL=http://localhost:3005/api
# NEXT_PUBLIC_SOCKET_URL=http://localhost:3005

# Windows Server (remplacer l'IP par celle du serveur) :
NEXT_PUBLIC_API_URL=http://192.168.2.118:3005/api
NEXT_PUBLIC_SOCKET_URL=http://192.168.2.118:3005

NEXT_PUBLIC_APP_NAME=InvoiceHub
