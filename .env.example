# ─────────────────────────────────────────────────────────────────────────────
#  InvoiceHub v2.0 — Variables d'environnement
#  Bridge Technologies Solutions — Douala, Cameroun
#
#  Instructions:
#  1. Copier ce fichier en .env
#  2. Remplir les valeurs manquantes (DB_PASSWORD, JWT_*_SECRET, etc.)
#  3. Ne JAMAIS committer .env dans git
#
#  Configurations:
#  - DEV LOCAL (sans Docker)     → NODE_ENV=development, DB en local
#  - DEV DOCKER (DB+Redis)       → NODE_ENV=development, DB via Docker
#  - PRODUCTION (Full Docker)    → NODE_ENV=production, tout en Docker
# ─────────────────────────────────────────────────────────────────────────────

# ── Mode & Ports ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3005
API_PREFIX=/api

# IP du serveur Windows sur le réseau local
# Trouver avec : ipconfig → Adresse IPv4
SERVER_IP=192.168.1.10

# ── Base de données PostgreSQL ───────────────────────────────────────────────
# DEV LOCAL (sans Docker) :
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/invoicehub
# DEV DOCKER (DB + API local) :
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/invoicehub
# PRODUCTION (tout en Docker) :
#   Construit automatiquement par docker-compose (db:5432)
DATABASE_URL=postgresql://postgres:${DB_PASSWORD:-password}@localhost:5432/invoicehub
DB_PASSWORD=dev_password_change_in_production

# ── Authentification (JWT) ───────────────────────────────────────────────────
# IMPORTANT : minimum 32 caractères alphanumériques pour chaque secret
JWT_ACCESS_SECRET=dev_access_secret_minimum_32_caracteres_long_ici
JWT_REFRESH_SECRET=dev_refresh_secret_minimum_32_caracteres_long_ici
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@bts.cm

# ── Cache & Queue (Redis / BullMQ) ───────────────────────────────────────────
# DEV LOCAL : redis://localhost:6379
# DEV DOCKER : redis://localhost:6379
# PRODUCTION : redis://redis:6379
REDIS_URL=redis://localhost:6379

# ── URLs de l'application ────────────────────────────────────────────────────
# DEV LOCAL   : http://localhost:3001 (frontend), http://localhost:3005 (API)
# PRODUCTION  : https://invoicehub.bridgetech-solutions
APP_URL=http://localhost:3001
BACKEND_URL=http://localhost:3005
CORS_ORIGINS=http://localhost:3001,http://localhost:3005

# ── Frontend Next.js (variables injectées au build) ──────────────────────────
# DEV LOCAL   : http://localhost:3005/api
# PRODUCTION  : https://api.invoicehub.bridgetech-solutions/api
NEXT_PUBLIC_API_URL=http://localhost:3005/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:3005

# ── TOTP Authenticator ───────────────────────────────────────────────────────
# Nom affiché dans l'application authenticator (Google Authenticator, Authy, etc.)
TOTP_ISSUER=InvoiceHub BTS

# ── Sauvegardes (Backups) ────────────────────────────────────────────────────
BACKUP_STORAGE_DISK=local
BACKUP_DIR=./uploads/backups
BACKUP_RETENTION_DAYS=30
BACKUP_CRON=30 15 * * *
BACKUP_INCLUDE_FILES=false
UPLOADS_DIR=./uploads
PGDUMP_PATH=pg_dump

# Amazon S3 / Cloudflare R2 / MinIO (si BACKUP_STORAGE_DISK=s3)
# S3_BUCKET=invoicehub-backups
# S3_REGION=eu-west-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=

# Google Cloud Storage (si BACKUP_STORAGE_DISK=google)
# GCS_BUCKET=invoicehub-backups
# GCS_KEY_FILE=./gcs-service-account.json

# Azure Blob Storage (si BACKUP_STORAGE_DISK=azure)
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=invoicehub-backups

# OneDrive for Business (si BACKUP_STORAGE_DISK=onedrive)
# ONEDRIVE_TENANT_ID=
# ONEDRIVE_CLIENT_ID=
# ONEDRIVE_CLIENT_SECRET=
# ONEDRIVE_DRIVE_ID=
# ONEDRIVE_FOLDER_PATH=InvoiceHub/Backups

# ── BTS Assistant (Ollama — IA locale) ───────────────────────────────────────
# DEV LOCAL : http://localhost:11434 (si Ollama installé localement)
# PRODUCTION : http://ollama:11434 (injecté par docker-compose)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_ENABLED=false
# Activer avec : docker compose --profile ai up -d
# En production Docker, OLLAMA_URL est injecté par docker-compose (http://ollama:11434)
# En dev local sans Docker : pointer sur l'instance Ollama locale
# OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_ENABLED=false
