# App
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# Database
DATABASE_URL=postgresql://postgres:password@db:5432/invoicehub

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@bts.cm

# App URL (pour les liens dans les emails)
APP_URL=http://localhost:3000

# TOTP Issuer (nom affiché dans l'app authenticator)
TOTP_ISSUER=InvoiceHub BTS

# DB Password (pour docker-compose)
DB_PASSWORD=strongpassword
