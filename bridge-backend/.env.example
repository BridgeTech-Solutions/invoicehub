# App
NODE_ENV=production
PORT=3000
API_PREFIX=/api

# IP du serveur Windows sur le réseau local
# Trouver avec : ipconfig → Adresse IPv4
# Exemple : 192.168.1.10
SERVER_IP=192.168.1.10

# Database
DATABASE_URL=postgresql://postgres:password@db:5432/invoicehub

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@bts.cm

# Redis (BullMQ — files d'attente)
REDIS_URL=redis://localhost:6379

# URL du frontend — utilisée pour les liens dans les emails (reset-password) et CORS
APP_URL=http://localhost:3001
# URL du backend — utilisée pour construire les URLs des fichiers uploadés (avatars, assets)
BACKEND_URL=http://localhost:3005
# Origines CORS supplémentaires (séparées par virgules)
# Local  : http://localhost:3001,http://localhost:3005
# Prod   : https://invoicehub.bridgetech-solutions
CORS_ORIGINS=http://localhost:3001,http://localhost:3005

# URLs frontend Next.js (baked at build time par docker-compose)
# Local : http://localhost:3005/api  |  Prod : https://api.invoicehub.bridgetech-solutions/api
NEXT_PUBLIC_API_URL=http://localhost:3005/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:3005

# TOTP Issuer (nom affiché dans l'app authenticator)
TOTP_ISSUER=InvoiceHub BTS

# DB Password (pour docker-compose)
DB_PASSWORD=strongpassword

# ── Backups ──────────────────────────────────────────────────────────────────
# Disque de stockage : local | s3 | google
BACKUP_STORAGE_DISK=local
BACKUP_DIR=./uploads/backups
BACKUP_RETENTION_DAYS=30
BACKUP_CRON=0 0 * * *
PGDUMP_PATH=pg_dump

# Amazon S3 / Cloudflare R2 / MinIO (si BACKUP_STORAGE_DISK=s3)
S3_BUCKET=invoicehub-backups
S3_REGION=eu-west-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=       # Laisser vide pour AWS S3. R2: https://ACCOUNT_ID.r2.cloudflarestorage.com

# Google Cloud Storage (si BACKUP_STORAGE_DISK=google)
GCS_BUCKET=invoicehub-backups
GCS_KEY_FILE=./gcs-service-account.json

# Microsoft Azure Blob Storage (si BACKUP_STORAGE_DISK=azure)
# Récupérer dans : Portail Azure → Compte de stockage → Sécurité + réseau → Clés d'accès
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=invoicehub-backups

# ── BTS Assistant (Ollama — IA locale) ───────────────────────────────────────
# Ollama tourne dans Docker — l'URL est gérée par docker-compose (http://ollama:11434)
# Mettre OLLAMA_ENABLED=true pour activer l'assistant BTS
# Le modèle sera téléchargé automatiquement par deploy.bat au premier démarrage
OLLAMA_MODEL=phi3:mini
OLLAMA_ENABLED=false
