// InvoiceHub v2.0 — Prisma Schema
// Mapped from invoicehub_schema_v2.sql
// Bridge Technologies Solutions (BTS) — Douala, Cameroun

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================================================
// ENUMS
// ================================================================

enum UserRole {
  admin
  commercial
  employee

  @@map("user_role")
}

enum UserStatus {
  active
  suspended
  pending_activation

  @@map("user_status")
}

enum ClientType {
  company
  individual

  @@map("client_type")
}

enum ClientStatus {
  active
  archived

  @@map("client_status")
}

enum ProductType {
  product
  service

  @@map("product_type")
}

enum ProductUnit {
  heure
  jour
  forfait
  piece
  licence
  mois
  annee

  @@map("product_unit")
}

enum DocumentType {
  proforma
  invoice

  @@map("document_type")
}

enum DiscountType {
  none
  percentage
  fixed

  @@map("discount_type")
}

enum ProformaStatus {
  draft
  sent
  accepted
  rejected
  expired

  @@map("proforma_status")
}

enum InvoiceType {
  standard
  acompte
  solde
  avoir
  recurring

  @@map("invoice_type")
}

enum InvoiceStatus {
  draft
  issued
  partially_paid
  paid
  cancelled
  overdue

  @@map("invoice_status")
}

enum PaymentMethod {
  virement
  especes
  cheque
  mobile_money
  autre

  @@map("payment_method")
}

enum RecurringInterval {
  monthly
  quarterly
  biannual
  annual

  @@map("recurring_interval")
}

enum BackupStatus {
  pending
  running
  success
  failed

  @@map("backup_status")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SOFT_DELETE
  RESTORE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGE
  PASSWORD_RESET
  ROLE_CHANGE
  STATUS_CHANGE
  CONVERT_TO_INVOICE
  PAYMENT_REGISTERED
  PAYMENT_DELETED
  EMAIL_SENT
  PDF_GENERATED
  EXPORT

  @@map("audit_action")
}

enum NotificationChannel {
  in_app
  email
  both

  @@map("notification_channel")
}

enum NotificationStatus {
  proforma_sent
  proforma_accepted
  proforma_rejected
  proforma_expired
  invoice_issued
  invoice_paid
  invoice_partially_paid
  invoice_overdue
  payment_registered
  reminder_sent
  user_created
  system

  @@map("notification_status")
}

// ================================================================
// MODELS
// ================================================================

model CompanySettings {
  id                           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  companyName                  String   @map("company_name") @db.VarChar(255)
  legalForm                    String?  @map("legal_form") @db.VarChar(100)
  taxNumber                    String?  @map("tax_number") @db.VarChar(100)
  rccm                         String?  @db.VarChar(100)
  address                      String
  city                         String   @default("Douala") @db.VarChar(100)
  country                      String   @default("Cameroun") @db.VarChar(100)
  postalBox                    String?  @map("postal_box") @db.VarChar(50)
  phone                        String   @db.VarChar(50)
  email                        String   @db.VarChar(255)
  website                      String?  @db.VarChar(255)
  logoPath                     String?  @map("logo_path") @db.VarChar(500)
  stampPath                    String?  @map("stamp_path") @db.VarChar(500)
  signaturePath                String?  @map("signature_path") @db.VarChar(500)
  defaultCurrency              String   @default("XAF") @map("default_currency") @db.Char(3)
  defaultTaxRate               Decimal  @default(19.25) @map("default_tax_rate") @db.Decimal(5, 2)
  companyCode                  String   @default("BTS") @map("company_code") @db.VarChar(10)
  defaultProformaValidityDays  Int      @default(30) @map("default_proforma_validity_days") @db.SmallInt
  defaultInvoiceDueDays        Int      @default(30) @map("default_invoice_due_days") @db.SmallInt
  sessionTimeoutMinutes        Int      @default(30) @map("session_timeout_minutes") @db.SmallInt
  maxLoginAttempts             Int      @default(5) @map("max_login_attempts") @db.SmallInt
  autoReminderDays             Int[]    @default([7, 14, 30]) @map("auto_reminder_days")
  metadata                     Json     @default("{}")
  createdAt                    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("company_settings")
}

model AgencyOffice {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code        String    @unique @db.VarChar(10)
  name        String    @db.VarChar(255)
  city        String?   @db.VarChar(100)
  address     String?
  isDefault   Boolean   @default(false) @map("is_default")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()

  proformas                  Proforma[]
  invoices                   Invoice[]
  documentSequences          DocumentSequence[]
  recurringInvoiceTemplates  RecurringInvoiceTemplate[]

  @@map("agency_offices")
}

model TaxRate {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String    @db.VarChar(100)
  code        String    @unique @db.VarChar(20)
  rate        Decimal   @db.Decimal(5, 2)
  description String?
  isDefault   Boolean   @default(false) @map("is_default")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()

  products    Product[]

  @@map("tax_rates")
}

model User {
  id                   String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  firstName            String      @map("first_name") @db.VarChar(100)
  lastName             String      @map("last_name") @db.VarChar(100)
  email                String      @unique @db.VarChar(255)
  phone                String?     @db.VarChar(50)
  avatarPath           String?     @map("avatar_path") @db.VarChar(500)
  signaturePath        String?     @map("signature_path") @db.VarChar(500)
  passwordHash         String      @map("password_hash") @db.VarChar(255)
  role                 UserRole    @default(employee)
  status               UserStatus  @default(pending_activation)
  mustChangePassword   Boolean     @default(true) @map("must_change_password")
  failedLoginAttempts  Int         @default(0) @map("failed_login_attempts") @db.SmallInt
  lastFailedLoginAt    DateTime?   @map("last_failed_login_at") @db.Timestamptz()
  lockedAt             DateTime?   @map("locked_at") @db.Timestamptz()
  lockReason           String?     @map("lock_reason") @db.VarChar(255)
  twoFactorEnabled     Boolean     @default(false) @map("two_factor_enabled")
  twoFactorSecret      String?     @map("two_factor_secret")
  twoFactorEnabledAt   DateTime?   @map("two_factor_enabled_at") @db.Timestamptz()
  language             String      @default("fr") @db.Char(2)
  timezone             String      @default("Africa/Douala") @db.VarChar(50)
  theme                String      @default("system") @db.VarChar(20)
  emailNotifications   Boolean     @default(true) @map("email_notifications")
  invoiceNotifications Boolean     @default(true) @map("invoice_notifications")
  lastLoginAt          DateTime?   @map("last_login_at") @db.Timestamptz()
  lastActivityAt       DateTime?   @map("last_activity_at") @db.Timestamptz()
  lastSummarySentAt    DateTime?   @map("last_summary_sent_at") @db.Timestamptz()
  metadata             Json        @default("{}")
  createdAt            DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt            DateTime?   @map("deleted_at") @db.Timestamptz()
  createdById          String?     @map("created_by") @db.Uuid
  createdBy            User?       @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers         User[]      @relation("UserCreatedBy")

  refreshTokens           RefreshToken[]
  loginHistory            LoginHistory[]
  passwordResetTokens     PasswordResetToken[]
  productCategories       ProductCategory[]
  products                Product[]
  clients                 Client[]
  proformasCreated        Proforma[]              @relation("ProformaCreatedBy")
  proformasAssigned       Proforma[]              @relation("ProformaAssignedTo")
  proformaStatusHistory   ProformaStatusHistory[]
  invoicesCreated         Invoice[]               @relation("InvoiceCreatedBy")
  invoicesAssigned        Invoice[]               @relation("InvoiceAssignedTo")
  invoicesCancelled       Invoice[]               @relation("InvoiceCancelledBy")
  invoiceStatusHistory    InvoiceStatusHistory[]
  payments                Payment[]
  recurringTemplates      RecurringInvoiceTemplate[]
  auditLogs               AuditLog[]
  notifications           Notification[]
  notificationSettings    NotificationSetting[]

  @@map("users")
}

model RefreshToken {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique @map("token_hash") @db.VarChar(255)
  deviceName   String?   @map("device_name") @db.VarChar(255)
  deviceInfo   Json      @default("{}") @map("device_info")
  ipAddress    String?   @map("ip_address")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz()
  revokeReason String?   @map("revoke_reason") @db.VarChar(100)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@map("refresh_tokens")
}

model LoginHistory {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email         String   @db.VarChar(255)
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  success       Boolean  @default(false)
  failureReason String?  @map("failure_reason") @db.VarChar(100)
  sessionId     String?  @map("session_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("login_history")
}

model PasswordResetToken {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz()
  usedAt     DateTime? @map("used_at") @db.Timestamptz()
  ipAddress  String?   @map("ip_address")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@map("password_reset_tokens")
}

model ProductCategory {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String    @unique @db.VarChar(100)
  description String?
  icon        String?   @db.VarChar(50)
  color       String?   @db.Char(7)
  sortOrder   Int       @default(0) @map("sort_order") @db.SmallInt
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()
  createdById String?   @map("created_by") @db.Uuid
  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  products    Product[]

  @@map("product_categories")
}

model Product {
  id            String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  categoryId    String?      @map("category_id") @db.Uuid
  category      ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name          String       @db.VarChar(255)
  reference     String?      @db.VarChar(100)
  type          ProductType  @default(product)
  description   String?
  unit          ProductUnit  @default(piece)
  unitPriceHt   Decimal      @default(0) @map("unit_price_ht") @db.Decimal(15, 2)
  taxRateId     String?      @map("tax_rate_id") @db.Uuid
  taxRate       TaxRate?     @relation(fields: [taxRateId], references: [id], onDelete: Restrict)
  taxRateValue  Decimal      @default(19.25) @map("tax_rate_value") @db.Decimal(5, 2)
  isActive      Boolean      @default(true) @map("is_active")
  metadata      Json         @default("{}")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz()
  createdById   String?      @map("created_by") @db.Uuid
  createdBy     User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)

  proformaLines ProformaLine[]
  invoiceLines  InvoiceLine[]

  @@unique([name, categoryId])
  @@map("products")
}

model Client {
  id                  String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  type                ClientType   @default(company)
  name                String       @db.VarChar(255)
  email               String?      @db.VarChar(255)
  phone               String?      @db.VarChar(50)
  phone2              String?      @map("phone_2") @db.VarChar(50)
  address             String?
  city                String?      @db.VarChar(100)
  country             String       @default("Cameroun") @db.VarChar(100)
  postalBox           String?      @map("postal_box") @db.VarChar(50)
  taxNumber           String?      @map("tax_number") @db.VarChar(100)
  rccm                String?      @db.VarChar(100)
  bankName            String?      @map("bank_name") @db.VarChar(255)
  bankAccount         String?      @map("bank_account") @db.VarChar(100)
  currency            String       @default("XAF") @db.Char(3)
  defaultPaymentTerms String?      @map("default_payment_terms")
  status              ClientStatus @default(active)
  internalNotes       String?      @map("internal_notes")
  metadata            Json         @default("{}")
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt           DateTime?    @map("deleted_at") @db.Timestamptz()
  createdById         String?      @map("created_by") @db.Uuid
  createdBy           User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)

  proformas                  Proforma[]
  invoices                   Invoice[]
  recurringInvoiceTemplates  RecurringInvoiceTemplate[]

  @@map("clients")
}

model DocumentSequence {
  id            String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  officeId      String       @map("office_id") @db.Uuid
  office        AgencyOffice @relation(fields: [officeId], references: [id], onDelete: Restrict)
  documentType  DocumentType @map("document_type")
  year          Int          @db.SmallInt
  month         Int          @db.SmallInt
  lastSequence  Int          @default(0) @map("last_sequence")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([officeId, documentType, year, month])
  @@map("document_sequences")
}

model Proforma {
  id                   String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  number               String         @unique @db.VarChar(50)
  officeId             String         @map("office_id") @db.Uuid
  office               AgencyOffice   @relation(fields: [officeId], references: [id], onDelete: Restrict)
  clientId             String         @map("client_id") @db.Uuid
  client               Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdById          String         @map("created_by") @db.Uuid
  createdBy            User           @relation("ProformaCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignedToId         String?        @map("assigned_to") @db.Uuid
  assignedTo           User?          @relation("ProformaAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  issueDate            DateTime       @default(dbgenerated("CURRENT_DATE")) @map("issue_date") @db.Date
  validUntil           DateTime       @map("valid_until") @db.Date
  subject              String?        @db.VarChar(500)
  notes                String?
  paymentConditions    String?        @map("payment_conditions")
  deliveryDelay        String?        @map("delivery_delay")
  warranty             String?
  currency             String         @default("XAF") @db.Char(3)
  subtotalHt           Decimal        @default(0) @map("subtotal_ht") @db.Decimal(15, 2)
  globalDiscountType   DiscountType   @default(none) @map("global_discount_type")
  globalDiscountValue  Decimal        @default(0) @map("global_discount_value") @db.Decimal(15, 2)
  globalDiscountAmount Decimal        @default(0) @map("global_discount_amount") @db.Decimal(15, 2)
  totalHt              Decimal        @default(0) @map("total_ht") @db.Decimal(15, 2)
  totalTax             Decimal        @default(0) @map("total_tax") @db.Decimal(15, 2)
  totalTtc             Decimal        @default(0) @map("total_ttc") @db.Decimal(15, 2)
  status               ProformaStatus @default(draft)
  lastSentAt           DateTime?      @map("last_sent_at") @db.Timestamptz()
  lastReminderAt       DateTime?      @map("last_reminder_at") @db.Timestamptz()
  reminderCount        Int            @default(0) @map("reminder_count") @db.SmallInt
  qrCodePath           String?        @map("qr_code_path") @db.VarChar(500)
  pdfPath              String?        @map("pdf_path") @db.VarChar(500)
  pdfGeneratedAt       DateTime?      @map("pdf_generated_at") @db.Timestamptz()
  metadata             Json           @default("{}")
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt            DateTime?      @map("deleted_at") @db.Timestamptz()

  lines         ProformaLine[]
  statusHistory ProformaStatusHistory[]
  invoices      Invoice[]

  @@map("proformas")
}

model ProformaLine {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  proformaId     String       @map("proforma_id") @db.Uuid
  proforma       Proforma     @relation(fields: [proformaId], references: [id], onDelete: Cascade)
  productId      String?      @map("product_id") @db.Uuid
  product        Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  sortOrder      Int          @default(0) @map("sort_order") @db.SmallInt
  designation    String       @db.VarChar(500)
  description    String?
  unit           ProductUnit  @default(piece)
  quantity       Decimal      @default(1) @db.Decimal(10, 3)
  unitPriceHt    Decimal      @default(0) @map("unit_price_ht") @db.Decimal(15, 2)
  discountType   DiscountType @default(none) @map("discount_type")
  discountValue  Decimal      @default(0) @map("discount_value") @db.Decimal(15, 2)
  discountAmount Decimal      @default(0) @map("discount_amount") @db.Decimal(15, 2)
  taxRate        Decimal      @default(19.25) @map("tax_rate") @db.Decimal(5, 2)
  subtotalHt     Decimal      @default(0) @map("subtotal_ht") @db.Decimal(15, 2)
  netHt          Decimal      @default(0) @map("net_ht") @db.Decimal(15, 2)
  taxAmount      Decimal      @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalTtc       Decimal      @default(0) @map("total_ttc") @db.Decimal(15, 2)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("proforma_lines")
}

model ProformaStatusHistory {
  id             String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  proformaId     String          @map("proforma_id") @db.Uuid
  proforma       Proforma        @relation(fields: [proformaId], references: [id], onDelete: Cascade)
  changedById    String          @map("changed_by") @db.Uuid
  changedBy      User            @relation(fields: [changedById], references: [id], onDelete: Restrict)
  previousStatus ProformaStatus? @map("previous_status")
  newStatus      ProformaStatus  @map("new_status")
  reason         String?
  changedAt      DateTime        @default(now()) @map("changed_at") @db.Timestamptz()

  @@map("proforma_status_history")
}

model Invoice {
  id                    String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  number                String        @unique @db.VarChar(50)
  officeId              String        @map("office_id") @db.Uuid
  office                AgencyOffice  @relation(fields: [officeId], references: [id], onDelete: Restrict)
  type                  InvoiceType   @default(standard)
  clientId              String        @map("client_id") @db.Uuid
  client                Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdById           String        @map("created_by") @db.Uuid
  createdBy             User          @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignedToId          String?       @map("assigned_to") @db.Uuid
  assignedTo            User?         @relation("InvoiceAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  proformaId            String?       @map("proforma_id") @db.Uuid
  proforma              Proforma?     @relation(fields: [proformaId], references: [id], onDelete: SetNull)
  parentInvoiceId       String?       @map("parent_invoice_id") @db.Uuid
  parentInvoice         Invoice?      @relation("InvoiceParent", fields: [parentInvoiceId], references: [id], onDelete: SetNull)
  childInvoices         Invoice[]     @relation("InvoiceParent")
  creditedInvoiceId     String?       @map("credited_invoice_id") @db.Uuid
  creditedInvoice       Invoice?      @relation("InvoiceAvoir", fields: [creditedInvoiceId], references: [id], onDelete: Restrict)
  creditNotes           Invoice[]     @relation("InvoiceAvoir")
  recurringTemplateId   String?       @map("recurring_template_id") @db.Uuid
  issueDate             DateTime      @default(dbgenerated("CURRENT_DATE")) @map("issue_date") @db.Date
  dueDate               DateTime      @map("due_date") @db.Date
  subject               String?       @db.VarChar(500)
  clientReference       String?       @map("client_reference") @db.VarChar(100)
  notes                 String?
  paymentConditions     String?       @map("payment_conditions")
  currency              String        @default("XAF") @db.Char(3)
  subtotalHt            Decimal       @default(0) @map("subtotal_ht") @db.Decimal(15, 2)
  globalDiscountType    DiscountType  @default(none) @map("global_discount_type")
  globalDiscountValue   Decimal       @default(0) @map("global_discount_value") @db.Decimal(15, 2)
  globalDiscountAmount  Decimal       @default(0) @map("global_discount_amount") @db.Decimal(15, 2)
  totalHt               Decimal       @default(0) @map("total_ht") @db.Decimal(15, 2)
  totalTax              Decimal       @default(0) @map("total_tax") @db.Decimal(15, 2)
  totalTtc              Decimal       @default(0) @map("total_ttc") @db.Decimal(15, 2)
  acomptePercentage     Decimal?      @map("acompte_percentage") @db.Decimal(5, 2)
  totalAcomptesDeducted Decimal       @default(0) @map("total_acomptes_deducted") @db.Decimal(15, 2)
  amountDue             Decimal       @default(0) @map("amount_due") @db.Decimal(15, 2)
  amountPaid            Decimal       @default(0) @map("amount_paid") @db.Decimal(15, 2)
  balanceDue            Decimal       @default(0) @map("balance_due") @db.Decimal(15, 2)
  status                InvoiceStatus @default(draft)
  lastSentAt            DateTime?     @map("last_sent_at") @db.Timestamptz()
  lastReminderAt        DateTime?     @map("last_reminder_at") @db.Timestamptz()
  reminderCount         Int           @default(0) @map("reminder_count") @db.SmallInt
  cancelledAt           DateTime?     @map("cancelled_at") @db.Timestamptz()
  cancelReason          String?       @map("cancel_reason")
  cancelledById         String?       @map("cancelled_by") @db.Uuid
  cancelledBy           User?         @relation("InvoiceCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  qrCodePath            String?       @map("qr_code_path") @db.VarChar(500)
  pdfPath               String?       @map("pdf_path") @db.VarChar(500)
  pdfGeneratedAt        DateTime?     @map("pdf_generated_at") @db.Timestamptz()
  metadata              Json          @default("{}")
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt             DateTime?     @map("deleted_at") @db.Timestamptz()

  lines         InvoiceLine[]
  statusHistory InvoiceStatusHistory[]
  payments      Payment[]

  @@map("invoices")
}

model InvoiceLine {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  invoiceId      String       @map("invoice_id") @db.Uuid
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId      String?      @map("product_id") @db.Uuid
  product        Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  sortOrder      Int          @default(0) @map("sort_order") @db.SmallInt
  designation    String       @db.VarChar(500)
  description    String?
  unit           ProductUnit  @default(piece)
  quantity       Decimal      @default(1) @db.Decimal(10, 3)
  unitPriceHt    Decimal      @default(0) @map("unit_price_ht") @db.Decimal(15, 2)
  discountType   DiscountType @default(none) @map("discount_type")
  discountValue  Decimal      @default(0) @map("discount_value") @db.Decimal(15, 2)
  discountAmount Decimal      @default(0) @map("discount_amount") @db.Decimal(15, 2)
  taxRate        Decimal      @default(19.25) @map("tax_rate") @db.Decimal(5, 2)
  subtotalHt     Decimal      @default(0) @map("subtotal_ht") @db.Decimal(15, 2)
  netHt          Decimal      @default(0) @map("net_ht") @db.Decimal(15, 2)
  taxAmount      Decimal      @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalTtc       Decimal      @default(0) @map("total_ttc") @db.Decimal(15, 2)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("invoice_lines")
}

model InvoiceStatusHistory {
  id             String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  invoiceId      String         @map("invoice_id") @db.Uuid
  invoice        Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  changedById    String         @map("changed_by") @db.Uuid
  changedBy      User           @relation(fields: [changedById], references: [id], onDelete: Restrict)
  previousStatus InvoiceStatus? @map("previous_status")
  newStatus      InvoiceStatus  @map("new_status")
  reason         String?
  changedAt      DateTime       @default(now()) @map("changed_at") @db.Timestamptz()

  @@map("invoice_status_history")
}

model Payment {
  id             String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  invoiceId      String        @map("invoice_id") @db.Uuid
  invoice        Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  paymentDate    DateTime      @default(dbgenerated("CURRENT_DATE")) @map("payment_date") @db.Date
  amount         Decimal       @db.Decimal(15, 2)
  method         PaymentMethod @default(virement)
  reference      String?       @db.VarChar(255)
  notes          String?
  attachmentPath String?       @map("attachment_path") @db.VarChar(500)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt      DateTime?     @map("deleted_at") @db.Timestamptz()
  createdById    String        @map("created_by") @db.Uuid
  createdBy      User          @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@map("payments")
}

model RecurringInvoiceTemplate {
  id                String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clientId          String            @map("client_id") @db.Uuid
  client            Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  officeId          String            @map("office_id") @db.Uuid
  office            AgencyOffice      @relation(fields: [officeId], references: [id], onDelete: Restrict)
  interval          RecurringInterval @default(monthly)
  nextInvoiceDate   DateTime          @map("next_invoice_date") @db.Date
  endDate           DateTime?         @map("end_date") @db.Date
  subject           String?           @db.VarChar(500)
  notes             String?
  paymentConditions String?           @map("payment_conditions")
  currency          String            @default("XAF") @db.Char(3)
  isActive          Boolean           @default(true) @map("is_active")
  lastGeneratedAt   DateTime?         @map("last_generated_at") @db.Timestamptz()
  metadata          Json              @default("{}")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt         DateTime?         @map("deleted_at") @db.Timestamptz()
  createdById       String            @map("created_by") @db.Uuid
  createdBy         User              @relation(fields: [createdById], references: [id], onDelete: Restrict)

  lines RecurringInvoiceTemplateLine[]

  @@map("recurring_invoice_templates")
}

model RecurringInvoiceTemplateLine {
  id             String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  templateId     String                   @map("template_id") @db.Uuid
  template       RecurringInvoiceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sortOrder      Int                      @default(0) @map("sort_order") @db.SmallInt
  designation    String                   @db.VarChar(500)
  description    String?
  unit           ProductUnit              @default(piece)
  quantity       Decimal                  @default(1) @db.Decimal(10, 3)
  unitPriceHt    Decimal                  @default(0) @map("unit_price_ht") @db.Decimal(15, 2)
  discountType   DiscountType             @default(none) @map("discount_type")
  discountValue  Decimal                  @default(0) @map("discount_value") @db.Decimal(15, 2)
  taxRate        Decimal                  @default(19.25) @map("tax_rate") @db.Decimal(5, 2)
  createdAt      DateTime                 @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("recurring_invoice_template_lines")
}

model Notification {
  id         String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId     String             @map("user_id") @db.Uuid
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationStatus
  title      String             @db.VarChar(255)
  message    String
  data       Json               @default("{}")
  isRead     Boolean            @default(false) @map("is_read")
  readAt     DateTime?          @map("read_at") @db.Timestamptz()
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz()

  @@map("notifications")
}

model NotificationSetting {
  id      String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId  String              @map("user_id") @db.Uuid
  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type    NotificationStatus
  channel NotificationChannel @default(both)
  enabled Boolean             @default(true)

  @@unique([userId, type])
  @@map("notification_settings")
}

model EmailTemplate {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(255)
  subject   String   @db.VarChar(500)
  bodyHtml  String   @map("body_html")
  variables Json     @default("[]")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("email_templates")
}

model AuditLog {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String?     @map("user_id") @db.Uuid
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      AuditAction
  tableName   String      @map("table_name") @db.VarChar(100)
  recordId    String?     @map("record_id") @db.Uuid
  oldData     Json?       @map("old_data")
  newData     Json?       @map("new_data")
  ipAddress   String?     @map("ip_address")
  userAgent   String?     @map("user_agent")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  @@map("audit_logs")
}

model Backup {
  id          String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  filename    String       @db.VarChar(500)
  sizeBytes   BigInt?      @map("size_bytes")
  status      BackupStatus @default(pending)
  errorMessage String?     @map("error_message")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  completedAt DateTime?    @map("completed_at") @db.Timestamptz()

  @@map("backups")
}
