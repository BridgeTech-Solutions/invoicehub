# ── Mode & Ports ────────────────────────────────────────────────────────────
# DEV LOCAL (sans Docker) : development
# DEV DOCKER : development
# PRODUCTION : production
NODE_ENV=development
PORT=3005
API_PREFIX=/api

# Doc Swagger : activée d'office hors production. En production, mettre true pour
# exposer /api/docs (sinon désactivée). Laisser vide/false en prod par défaut.
ENABLE_DOCS=false

# IP du serveur Windows sur le réseau local (ipconfig → Adresse IPv4)
SERVER_IP=192.168.1.10

# ── Base de données ──────────────────────────────────────────────────────────
# DEV LOCAL (sans Docker) :
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/invoicehub
# DEV DOCKER + API local :
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/invoicehub
# DEV DOCKER + API dans Docker :
#   DATABASE_URL=postgresql://postgres:password@db:5432/invoicehub
# PRODUCTION :
#   DATABASE_URL sera construit par docker-compose (db:5432)
DATABASE_URL=postgresql://postgres:${DB_PASSWORD:-password}@localhost:5432/invoicehub

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=dev_access_secret_minimum_32_caracteres_long
JWT_REFRESH_SECRET=dev_refresh_secret_minimum_32_caracteres_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@bts.cm

# ── Redis (BullMQ — files d'attente) ─────────────────────────────────────────
# DEV LOCAL : redis://localhost:6379
# DEV DOCKER + API local : redis://localhost:6379
# DEV DOCKER + API dans Docker : redis://redis:6379
# PRODUCTION : redis://redis:6379
REDIS_URL=redis://localhost:6379

# ── URLs locales (dev local sans Docker) ─────────────────────────────────────
# Laisser ces URLs pour dev local
APP_URL=http://localhost:3001
BACKEND_URL=http://localhost:3005
CORS_ORIGINS=http://localhost:3001,http://localhost:3005

# Frontend Next.js URLs
NEXT_PUBLIC_API_URL=http://localhost:3005/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:3005

# ── TOTP ──────────────────────────────────────────────────────────────────────
TOTP_ISSUER=InvoiceHub BTS

# ── DB Password (pour docker-compose) ─────────────────────────────────────────
DB_PASSWORD=dev_password_change_in_production

# ── Backups ──────────────────────────────────────────────────────────────────
BACKUP_STORAGE_DISK=local
BACKUP_DIR=./uploads/backups
BACKUP_RETENTION_DAYS=30
BACKUP_CRON=30 15 * * *
BACKUP_INCLUDE_FILES=false
UPLOADS_DIR=./uploads
PGDUMP_PATH=pg_dump

# Amazon S3 / Cloudflare R2 / MinIO (si BACKUP_STORAGE_DISK=s3)
# S3_BUCKET=invoicehub-backups
# S3_REGION=eu-west-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=

# Google Cloud Storage (si BACKUP_STORAGE_DISK=google)
# GCS_BUCKET=invoicehub-backups
# GCS_KEY_FILE=./gcs-service-account.json

# Azure Blob Storage (si BACKUP_STORAGE_DISK=azure)
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=invoicehub-backups

# OneDrive for Business (si BACKUP_STORAGE_DISK=onedrive)
# ONEDRIVE_TENANT_ID=
# ONEDRIVE_CLIENT_ID=
# ONEDRIVE_CLIENT_SECRET=
# ONEDRIVE_DRIVE_ID=
# ONEDRIVE_FOLDER_PATH=InvoiceHub/Backups

# ── BTS Assistant (Ollama — IA locale) ───────────────────────────────────────
# DEV : http://localhost:11434 (si Ollama local)
# PROD Docker : http://ollama:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_ENABLED=false
