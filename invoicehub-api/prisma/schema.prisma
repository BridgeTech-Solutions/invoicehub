model BankAccount {
  id                  String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                String          @db.VarChar(255)
  accountType         BankAccountType @default(checking) @map("account_type")
  bankName            String          @map("bank_name") @db.VarChar(255)
  branchName          String?         @map("branch_name") @db.VarChar(255)
  accountNumber       String?         @map("account_number") @db.VarChar(100)
  iban                String?         @db.VarChar(50)
  swiftBic            String?         @map("swift_bic") @db.VarChar(20)
  currency            String          @default("XAF") @db.Char(3)
  openingBalance      Decimal         @default(0) @map("opening_balance") @db.Decimal(15, 2)
  openingBalanceDate  DateTime        @default(dbgenerated("CURRENT_DATE")) @map("opening_balance_date") @db.Date
  currentBalance      Decimal         @default(0) @map("current_balance") @db.Decimal(15, 2)
  lastReconciledDate  DateTime?       @map("last_reconciled_date") @db.Date
  isDefault           Boolean         @default(false) @map("is_default")
  isActive            Boolean         @default(true) @map("is_active")
  color               String?         @db.Char(7)
  icon                String?         @db.VarChar(50)
  accountingAccount   String?         @default("5211") @map("accounting_account") @db.VarChar(20)
  lowBalanceAlert     Decimal?        @map("low_balance_alert") @db.Decimal(15, 2)
  alertEmail          String?         @map("alert_email") @db.VarChar(255)
  notes               String?
  metadata            Json            @default("{}")
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt           DateTime?       @map("deleted_at") @db.Timestamptz()
  createdById         String?         @map("created_by") @db.Uuid
  createdBy           User?           @relation("BankAccountCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  transactions    BankTransaction[]
  imports         BankStatementImport[]
  reconciliations BankReconciliation[]
  payments        Payment[]            @relation("PaymentBankAccount")
  supplierPayments    SupplierPayment[]    @relation("SPaymentBankAccount")
  chartOfAccounts     ChartOfAccount[]
  accountingJournals  AccountingJournal[]
  profileOverride BankProfileOverride? @relation("BankProfileOverride")
  matchingRules   BankMatchingRule[]   @relation("BankMatchingRules")
  invoices        Invoice[]            @relation("InvoiceBankAccount")
  proformas       Proforma[]           @relation("ProformaBankAccount")

  @@map("bank_accounts")
}

model BankTransaction {
  id                  String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bankAccountId       String               @map("bank_account_id") @db.Uuid
  bankAccount         BankAccount          @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  transactionDate     DateTime             @map("transaction_date") @db.Date
  valueDate           DateTime?            @map("value_date") @db.Date
  type                BankTransactionType
  amount              Decimal              @db.Decimal(15, 2)
  balanceAfter        Decimal?             @map("balance_after") @db.Decimal(15, 2)
  label               String               @db.VarChar(500)
  reference           String?              @db.VarChar(255)
  category            String?              @db.VarChar(100)
  source              String               @default("manual") @db.VarChar(50)
  contentHash         String?              @map("content_hash") @db.VarChar(64)
  importId            String?              @map("import_id") @db.Uuid
  import              BankStatementImport? @relation(fields: [importId], references: [id], onDelete: SetNull)
  reconciliationStatus ReconciliationStatus @default(pending) @map("reconciliation_status")
  reconciledAt        DateTime?            @map("reconciled_at") @db.Timestamptz()
  reconciledById      String?              @map("reconciled_by") @db.Uuid
  reconciledBy        User?                @relation("BankTransactionReconciledBy", fields: [reconciledById], references: [id], onDelete: SetNull)
  matchedEntityType   String?              @map("matched_entity_type") @db.VarChar(50)
  matchedEntityId     String?              @map("matched_entity_id") @db.Uuid
  notes               String?
  metadata            Json                 @default("{}")
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  createdById         String?              @map("created_by") @db.Uuid
  createdBy           User?                @relation("BankTransactionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  payments         Payment[]         @relation("PaymentBankTransaction")
  supplierPayments SupplierPayment[] @relation("SPaymentBankTransaction")

  @@unique([bankAccountId, contentHash], name: "uq_bank_transaction_hash")
  @@map("bank_transactions")
}

model BankStatementImport {
  id             String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bankAccountId  String           @map("bank_account_id") @db.Uuid
  bankAccount    BankAccount      @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  filename       String           @db.VarChar(255)
  filePath       String?          @map("file_path") @db.VarChar(500)
  fileFormat     String           @default("csv") @map("file_format") @db.VarChar(20)
  periodStart    DateTime         @map("period_start") @db.Date
  periodEnd      DateTime         @map("period_end") @db.Date
  totalCredits   Decimal          @default(0) @map("total_credits") @db.Decimal(15, 2)
  totalDebits    Decimal          @default(0) @map("total_debits") @db.Decimal(15, 2)
  nbTransactions Int              @default(0) @map("nb_transactions")
  nbMatched      Int              @default(0) @map("nb_matched")
  nbUnmatched    Int              @default(0) @map("nb_unmatched")
  status         BankImportStatus @default(pending)
  errorMessage   String?          @map("error_message")
  jobId          String?          @map("job_id") @db.VarChar(100)
  previewData    Json?            @map("preview_data")
  detectedFormat Json?            @map("detected_format")
  importedById   String?          @map("imported_by") @db.Uuid
  importedBy     User?            @relation("BankStatementImportedBy", fields: [importedById], references: [id], onDelete: SetNull)
  importedAt     DateTime         @default(now()) @map("imported_at") @db.Timestamptz()
  processedAt    DateTime?        @map("processed_at") @db.Timestamptz()

  transactions BankTransaction[]

  @@map("bank_statement_imports")
}

model BankReconciliation {
  id                       String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bankAccountId            String      @map("bank_account_id") @db.Uuid
  bankAccount              BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  periodStart              DateTime    @map("period_start") @db.Date
  periodEnd                DateTime    @map("period_end") @db.Date
  openingBalance           Decimal     @default(0) @map("opening_balance") @db.Decimal(15, 2)
  closingBalanceStatement  Decimal     @default(0) @map("closing_balance_statement") @db.Decimal(15, 2)
  closingBalanceSystem     Decimal     @default(0) @map("closing_balance_system") @db.Decimal(15, 2)
  isBalanced               Boolean     @default(false) @map("is_balanced")
  status                   String      @default("in_progress") @db.VarChar(20)
  notes                    String?
  completedAt              DateTime?   @map("completed_at") @db.Timestamptz()
  completedById            String?     @map("completed_by") @db.Uuid
  completedBy              User?       @relation("BankReconciliationCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  reviewedById             String?     @map("reviewed_by") @db.Uuid
  reviewedBy               User?       @relation("BankReconciliationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt               DateTime?   @map("reviewed_at") @db.Timestamptz()
  createdAt                DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  createdById              String?     @map("created_by") @db.Uuid
  createdBy                User?       @relation("BankReconciliationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@map("bank_reconciliations")
}

model BankProfileOverride {
  id            String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bankAccountId String      @unique @map("bank_account_id") @db.Uuid
  bankAccount   BankAccount @relation("BankProfileOverride", fields: [bankAccountId], references: [id], onDelete: Cascade)
  profileData   Json        @map("profile_data")
  verifiedCount Int         @default(1) @map("verified_count")
  isVerified    Boolean     @default(false) @map("is_verified")
  createdById   String      @map("created_by") @db.Uuid
  createdBy     User        @relation("BankProfileCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  @@map("bank_profile_overrides")
}

model BankMatchingRule {
  id            String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bankAccountId String?      @map("bank_account_id") @db.Uuid
  bankAccount   BankAccount? @relation("BankMatchingRules", fields: [bankAccountId], references: [id], onDelete: SetNull)
  labelContains String       @map("label_contains") @db.VarChar(255)
  entityType    String       @map("entity_type") @db.VarChar(50)
