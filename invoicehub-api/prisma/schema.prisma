model ChartOfAccount {
  accountNumber        String         @id @map("account_number") @db.VarChar(20)
  accountClass         AccountClass   @map("account_class")
  name                 String         @db.VarChar(255)
  shortName            String?        @map("short_name") @db.VarChar(100)
  accountNature        AccountNature  @default(debit_normal) @map("account_nature")
  parentAccountNumber  String?        @map("parent_account_number") @db.VarChar(20)
  parent               ChartOfAccount? @relation("CoaHierarchy", fields: [parentAccountNumber], references: [accountNumber], onDelete: SetNull)
  children             ChartOfAccount[] @relation("CoaHierarchy")
  isDetailAccount      Boolean        @default(true) @map("is_detail_account")
  isSystem             Boolean        @default(false) @map("is_system")
  isActive             Boolean        @default(true) @map("is_active")
  allowsReconciliation Boolean        @default(false) @map("allows_reconciliation")
  isBankAccount        Boolean        @default(false) @map("is_bank_account")
  linkedBankAccountId  String?        @map("linked_bank_account_id") @db.Uuid
  linkedBankAccount    BankAccount?   @relation(fields: [linkedBankAccountId], references: [id], onDelete: SetNull)
  description          String?
  notes                String?
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  createdById          String?        @map("created_by") @db.Uuid
  createdBy            User?          @relation("CoaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  journalEntryLines JournalEntryLine[]

  @@map("chart_of_accounts")
}

/// Modèle paramétrable des états financiers (« façon Sage ») : chaque poste
/// (rubrique) du bilan est défini par des sources = fourchettes de comptes +
/// règle de signe (sources en JSONB). Éditable par la DAF.
model StatementRubrique {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  side       String   @db.VarChar(10)            // 'actif' | 'passif'
  masseCode  String   @map("masse_code") @db.VarChar(10)
  masseLabel String   @map("masse_label") @db.VarChar(150)
  masseOrder Int      @map("masse_order")
  code       String   @unique @db.VarChar(10)    // code de poste SYSCOHADA (BA, BI…)
  label      String   @db.VarChar(255)
  lineOrder  Int      @map("line_order")
  isResult   Boolean  @default(false) @map("is_result")
  sources    Json     @default("[]")             // RubriqueSource[]
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("statement_rubriques")
}

model FiscalPeriod {
  id           String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String              @db.VarChar(100)
  fiscalYear   Int                 @map("fiscal_year") @db.SmallInt
  periodType   String              @default("month") @map("period_type") @db.VarChar(20)
  startDate    DateTime            @map("start_date") @db.Date
  endDate      DateTime            @map("end_date") @db.Date
  status       FiscalPeriodStatus  @default(open)
  closedAt     DateTime?           @map("closed_at") @db.Timestamptz()
  closedById   String?             @map("closed_by") @db.Uuid
  closedBy     User?               @relation("FiscalPeriodClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  lockedAt     DateTime?           @map("locked_at") @db.Timestamptz()
  lockedById   String?             @map("locked_by") @db.Uuid
  lockedBy     User?               @relation("FiscalPeriodLockedBy", fields: [lockedById], references: [id], onDelete: SetNull)
  notes        String?
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  createdById  String?             @map("created_by") @db.Uuid
  createdBy    User?               @relation("FiscalPeriodCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  journalEntries  JournalEntry[]
  taxDeclarations TaxDeclaration[]

  @@unique([fiscalYear, periodType, startDate])
  @@map("fiscal_periods")
}

model AccountingJournal {
  id              String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code            String      @unique @db.VarChar(20)
  name            String      @db.VarChar(100)
  description     String?     @db.Text
