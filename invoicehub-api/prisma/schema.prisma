// InvoiceHub v3.0 — Prisma Schema
// Mapped from invoicehub_schema_v3.sql
// Bridge Technologies Solutions (BTS) — Douala, Cameroun

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================================================
// ENUMS
// ================================================================

enum UserStatus {
  active
  suspended
  pending_activation

  @@map("user_status")
}

enum ClientType {
  company
  individual

  @@map("client_type")
}

enum ClientStatus {
  active
  archived

  @@map("client_status")
}

enum ProductType {
  product
  service

  @@map("product_type")
}


enum DocumentType {
  proforma
  invoice
  purchase_order
  supplier_invoice
  expense
  delivery_note

  @@map("document_type")
}

enum DiscountType {
  none
  percentage
  fixed

  @@map("discount_type")
}

enum ProformaStatus {
  draft
  sent
  accepted
  rejected
  expired

  @@map("proforma_status")
}

enum InvoiceType {
  standard
  acompte
  solde
  avoir
  recurring

  @@map("invoice_type")
}

enum InvoiceStatus {
  draft
  issued
  partially_paid
  paid
  cancelled
  overdue

  @@map("invoice_status")
}

enum PaymentMethod {
  virement
  especes
  cheque
  mobile_money
  autre

  @@map("payment_method")
}

enum RecurringInterval {
  monthly
  quarterly
  biannual
  annual

  @@map("recurring_interval")
}

enum BackupStatus {
  pending
  running
  success
  failed

  @@map("backup_status")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SOFT_DELETE
  RESTORE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGE
  PASSWORD_RESET
  ROLE_CHANGE
  STATUS_CHANGE
  CONVERT_TO_INVOICE
  PAYMENT_REGISTERED
  PAYMENT_DELETED
  EMAIL_SENT
  PDF_GENERATED
  EXPORT
  APPROVAL_REQUESTED
  APPROVAL_DECISION
  APPROVED
  REJECTED
  RECONCILED
  STOCK_ADJUSTED
  JOURNAL_ENTRY_CREATED
  JOURNAL_ENTRY_VALIDATED
  FISCAL_PERIOD_CLOSED
  ROLE_PERMISSION_CHANGED
  WEBHOOK_TRIGGERED
  BANK_IMPORT
  EXPENSE_SUBMITTED
  EXPENSE_APPROVED
  EXPENSE_REJECTED
  JOB_FAILED

  @@map("audit_action")
}

enum NotificationChannel {
  in_app
  email
  both

  @@map("notification_channel")
}

enum NotificationStatus {
  proforma_sent
  proforma_accepted
  proforma_rejected
  proforma_expired
  invoice_issued
  invoice_paid
  invoice_partially_paid
  invoice_overdue
  payment_registered
  reminder_sent
  user_created
  system
  approval_requested
  approval_approved
  approval_rejected
  approval_expired
  approval_delegated
  purchase_order_created
  purchase_order_approved
  purchase_order_rejected
  supplier_invoice_received
  supplier_invoice_due
  expense_submitted
  expense_approved
  expense_rejected
  low_stock_alert
  bank_reconciliation_pending
  fiscal_period_closing
  role_changed
  budget_exceeded
  accounting_entry_failed

  @@map("notification_status")
}

// ================================================================
// ENUMS v3 — Modules Fournisseurs, Stock, Dépenses, Banque,
//            Comptabilité, Paramètres avancés
// ================================================================

// --- Fournisseurs / Achats ---

enum SupplierStatus {
  active
  suspended
  archived

  @@map("supplier_status")
}

enum PurchaseOrderStatus {
  draft
  sent
  confirmed
  partially_received
  received
  invoiced
  cancelled
  closed

  @@map("purchase_order_status")
}

enum SupplierInvoiceStatus {
  draft
  received
  validated
  partially_paid
  paid
  disputed
  cancelled

  @@map("supplier_invoice_status")
}

enum StockMovementType {
  purchase_receipt
  sale
  adjustment_in
  adjustment_out
  write_off
  return_supplier
  return_customer
  initial_stock
  transfer_in
  transfer_out

  @@map("stock_movement_type")
}

enum DeliveryStatus {
  pending
  partial
  complete
  cancelled

  @@map("delivery_status")
}

// --- Dépenses ---

enum ExpenseStatus {
  draft
  submitted
  approved
  rejected
  paid
  cancelled

  @@map("expense_status")
}

enum ExpenseFrequency {
  once
  weekly
  monthly
  quarterly
  annual

  @@map("expense_frequency")
}

// --- Banque ---

enum BankAccountType {
  checking
  savings
  petty_cash
  mobile_money
  term_deposit

  @@map("bank_account_type")
}

enum BankTransactionType {
  debit
  credit

  @@map("bank_transaction_type")
}

enum ReconciliationStatus {
  pending
  reconciled
  unmatched
  ignored

  @@map("reconciliation_status")
}

enum BankImportStatus {
  pending
  processing
  completed
  failed
  cancelled

  @@map("bank_import_status")
}

// --- Comptabilité SYSCOHADA ---

enum JournalType {
  sales
  purchases
  bank
  cash
  operations
  misc
  opening
  closing

  @@map("journal_type")
}

enum AccountClass {
  c1 @map("1")
  c2 @map("2")
  c3 @map("3")
  c4 @map("4")
  c5 @map("5")
  c6 @map("6")
  c7 @map("7")
  c8 @map("8")

  @@map("account_class")
}

enum AccountNature {
  debit_normal
  credit_normal

  @@map("account_nature")
}

enum EntryStatus {
  draft
  validated
  locked
  cancelled

  @@map("entry_status")
}

enum FiscalPeriodStatus {
  open
  closed
  locked

  @@map("fiscal_period_status")
}

// --- Paramètres avancés ---

enum CustomFieldType {
  text
  number
  date
  boolean
  select
  multi_select
  textarea
  email
  phone
  url

  @@map("custom_field_type")
}

enum CustomFieldEntity {
  client
  product
  invoice
  proforma
  supplier
  purchase_order
  expense
  user

  @@map("custom_field_entity")
}

enum ExportFormat {
  csv
  excel
  pdf
  json
  sage_csv
  ciel_csv
  dsf_xml

  @@map("export_format")
}

enum ExportStatus {
  pending
  running
  completed
  failed
  expired

  @@map("export_status")
}

// --- Workflow d'Approbation ---

enum ApprovalDocumentType {
  invoice
  proforma
  purchase_order
  supplier_invoice
  expense

  @@map("approval_document_type")
}

enum ApprovalRequestStatus {
  pending
  approved
  rejected
  cancelled
  expired

  @@map("approval_request_status")
}

enum ApprovalDecisionType {
  approved
  rejected
  delegated

  @@map("approval_decision_type")
}

enum ApprovalTriggerOperator {
  gte
  lte
  eq
  gt
  lt

  @@map("approval_trigger_operator")
}

// ================================================================
// MODELS
// ================================================================

model Role {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String    @unique @db.VarChar(100)
  displayName String    @map("display_name") @db.VarChar(255)
  description String?
  color       String?   @db.Char(7)
  icon        String?   @db.VarChar(50)
  isSystem    Boolean   @default(false) @map("is_system")
  permissions String[]  @default([])
  createdById String?   @map("created_by") @db.Uuid
  createdBy   User?     @relation("RoleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()

  users User[] @relation("UserRole")

  @@map("roles")
}

model CompanySettings {
  id                           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  companyName                  String   @map("company_name") @db.VarChar(255)
  legalForm                    String?  @map("legal_form") @db.VarChar(100)
  taxNumber                    String?  @map("tax_number") @db.VarChar(100)
  rccm                         String?  @db.VarChar(100)
  address                      String
  city                         String   @default("Douala") @db.VarChar(100)
  country                      String   @default("Cameroun") @db.VarChar(100)
  postalBox                    String?  @map("postal_box") @db.VarChar(50)
  phone                        String   @db.VarChar(50)
  email                        String   @db.VarChar(255)
  website                      String?  @db.VarChar(255)
  logoPath                     String?  @map("logo_path") @db.VarChar(500)
  stampPath                    String?  @map("stamp_path") @db.VarChar(500)
  signaturePath                String?  @map("signature_path") @db.VarChar(500)
  headerImagePath              String?  @map("header_image_path") @db.VarChar(500)
  footerImagePath              String?  @map("footer_image_path") @db.VarChar(500)
  footerSafeZonePx             Int      @default(0) @map("footer_safe_zone_px") @db.SmallInt
  defaultCurrency              String   @default("XAF") @map("default_currency") @db.Char(3)
  defaultTaxRate               Decimal  @default(19.25) @map("default_tax_rate") @db.Decimal(5, 2)
  companyCode                  String   @default("BTS") @map("company_code") @db.VarChar(10)
  defaultProformaValidityDays  Int      @default(30) @map("default_proforma_validity_days") @db.SmallInt
  defaultInvoiceDueDays        Int      @default(30) @map("default_invoice_due_days") @db.SmallInt
  sessionTimeoutMinutes        Int      @default(30) @map("session_timeout_minutes") @db.SmallInt
  maxLoginAttempts             Int      @default(5) @map("max_login_attempts") @db.SmallInt
  require2FA                   Boolean  @default(false) @map("require_2fa")
  autoReminderDays             Int[]    @default([7, 14, 30]) @map("auto_reminder_days")
  reminderEscalation           Json     @default("{}") @map("reminder_escalation")
  initialStockAccount          String   @default("1042") @map("initial_stock_account") @db.VarChar(20)
  escompteAccountingAccount    String   @default("673") @map("escompte_accounting_account") @db.VarChar(20)
  collectedTaxAccount          String   @default("4431") @map("collected_tax_account") @db.VarChar(20)
  deductibleTaxAccount         String   @default("4452") @map("deductible_tax_account") @db.VarChar(20)
  stockAccount                 String   @default("3111") @map("stock_account") @db.VarChar(20)
  stockVariationAccount        String   @default("6031") @map("stock_variation_account") @db.VarChar(20)
  stockLossAccount             String   @default("6032") @map("stock_loss_account") @db.VarChar(20)
  defaultClientAccount         String   @default("4111") @map("default_client_account") @db.VarChar(20)
  defaultSupplierAccount       String   @default("4011") @map("default_supplier_account") @db.VarChar(20)
  defaultBankAccount           String   @default("5211") @map("default_bank_account") @db.VarChar(20)
  defaultSalesGoodsAccount     String   @default("7011") @map("default_sales_goods_account") @db.VarChar(20)
  defaultSalesServiceAccount   String   @default("7061") @map("default_sales_service_account") @db.VarChar(20)
  defaultPurchaseAccount       String   @default("6011") @map("default_purchase_account") @db.VarChar(20)
  defaultExpenseAccount        String   @default("6251") @map("default_expense_account") @db.VarChar(20)
  useAdvanceAccount            Boolean  @default(false) @map("use_advance_account")
  advanceAccount               String   @default("4191") @map("advance_account") @db.VarChar(20)
  // Retenue à la source subie (acompte IR / précompte prélevé par le client) —
  // compte 4492 « État, avances et acomptes versés sur impôts », taux 2,2 % par défaut.
  withholdingAccount           String   @default("4492") @map("withholding_account") @db.VarChar(20)
  withholdingRate              Decimal  @default(2.2) @map("withholding_rate") @db.Decimal(5, 2)
  metadata                     Json     @default("{}")
  createdAt                    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("company_settings")
}

model AgencyOffice {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code        String    @unique @db.VarChar(10)
  name        String    @db.VarChar(255)
  city        String?   @db.VarChar(100)
  address     String?
  isDefault   Boolean   @default(false) @map("is_default")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()

  proformas                  Proforma[]
  invoices                   Invoice[]
  documentSequences          DocumentSequence[]
  recurringInvoiceTemplates  RecurringInvoiceTemplate[]
  users                      User[]          @relation("UserOffice")
  purchaseOrders             PurchaseOrder[]
  supplierInvoices           SupplierInvoice[]
  expenses                   Expense[]

  @@map("agency_offices")
}

model Unit {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code        String   @unique @db.VarChar(20)
  label       String   @db.VarChar(50)
  labelPlural String?  @map("label_plural") @db.VarChar(50)
  showOnPdf   Boolean  @default(true) @map("show_on_pdf")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("units")
}

model TaxRate {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String    @db.VarChar(100)
  code        String    @unique @db.VarChar(20)
  rate        Decimal   @db.Decimal(5, 2)
  description String?
  isDefault              Boolean   @default(false) @map("is_default")
  isActive               Boolean   @default(true) @map("is_active")
  collectedTaxAccount    String?   @default("4431") @map("collected_tax_account") @db.VarChar(20)
  deductibleTaxAccount   String?   @default("4452") @map("deductible_tax_account") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()

  products    Product[]

  @@map("tax_rates")
}

model User {
  id                   String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  firstName            String      @map("first_name") @db.VarChar(100)
  lastName             String      @map("last_name") @db.VarChar(100)
  email                String      @unique @db.VarChar(255)
  phone                String?     @db.VarChar(50)
  avatarPath           String?     @map("avatar_path") @db.VarChar(500)
  signaturePath        String?     @map("signature_path") @db.VarChar(500)
  passwordHash         String      @map("password_hash") @db.VarChar(255)
  roleId               String      @map("role_id") @db.Uuid
  role                 Role        @relation("UserRole", fields: [roleId], references: [id], onDelete: Restrict)
  status               UserStatus  @default(pending_activation)
  isOwner              Boolean     @default(false) @map("is_owner")
  mustChangePassword   Boolean     @default(true) @map("must_change_password")
  failedLoginAttempts  Int         @default(0) @map("failed_login_attempts") @db.SmallInt
  lastFailedLoginAt    DateTime?   @map("last_failed_login_at") @db.Timestamptz()
  lockedAt             DateTime?   @map("locked_at") @db.Timestamptz()
  lockReason           String?     @map("lock_reason") @db.VarChar(255)
  twoFactorEnabled     Boolean     @default(false) @map("two_factor_enabled")
  twoFactorSecret      String?     @map("two_factor_secret")
  twoFactorEnabledAt   DateTime?   @map("two_factor_enabled_at") @db.Timestamptz()
  twoFactorBackupCodes String[]    @default([]) @map("two_factor_backup_codes")
  language             String      @default("fr") @db.Char(2)
  timezone             String      @default("Africa/Douala") @db.VarChar(50)
  theme                String      @default("system") @db.VarChar(20)
  emailNotifications   Boolean     @default(true) @map("email_notifications")
  invoiceNotifications Boolean     @default(true) @map("invoice_notifications")
  lastLoginAt          DateTime?   @map("last_login_at") @db.Timestamptz()
  lastActivityAt       DateTime?   @map("last_activity_at") @db.Timestamptz()
  lastSummarySentAt    DateTime?   @map("last_summary_sent_at") @db.Timestamptz()
  department           String?     @db.VarChar(100)
  jobTitle             String?     @map("job_title") @db.VarChar(100)
  employeeId           String?     @unique @map("employee_id") @db.VarChar(50)
  officeId             String?     @map("office_id") @db.Uuid
  office               AgencyOffice? @relation("UserOffice", fields: [officeId], references: [id], onDelete: SetNull)
  metadata             Json        @default("{}")
  createdAt            DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt            DateTime?   @map("deleted_at") @db.Timestamptz()
  createdById          String?     @map("created_by") @db.Uuid
  createdBy            User?       @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers         User[]      @relation("UserCreatedBy")
  rolesCreated                     Role[]                       @relation("RoleCreatedBy")
  suppliersCreated                 Supplier[]                   @relation("SupplierCreatedBy")
  purchaseOrdersCreated            PurchaseOrder[]              @relation("POCreatedBy")
  purchaseOrdersAssigned           PurchaseOrder[]              @relation("POAssignedTo")
  purchaseOrdersApproved           PurchaseOrder[]              @relation("POApprovedBy")
  purchaseOrderStatusChanges       PurchaseOrderStatusHistory[] @relation("POStatusChangedBy")
  supplierInvoicesCreated          SupplierInvoice[]            @relation("SICreatedBy")
  supplierInvoicesValidated        SupplierInvoice[]            @relation("SIValidatedBy")
  supplierInvoiceStatusChanges     SupplierInvoiceStatusHistory[] @relation("SIStatusChangedBy")
  supplierPaymentsCreated          SupplierPayment[]            @relation("SPaymentCreatedBy")
  supplierPaymentsReconciled       SupplierPayment[]            @relation("SPaymentReconciledBy")
  stockMovementsCreated            StockMovement[]              @relation("StockMovementCreatedBy")
  expenseCategoriesCreated         ExpenseCategory[]            @relation("ExpenseCategoryCreatedBy")
  expensesCreated                  Expense[]                    @relation("ExpenseCreatedBy")
  expensesSubmitted                Expense[]                    @relation("ExpenseSubmittedBy")
  expensesApproved                 Expense[]                    @relation("ExpenseApprovedBy")
  expensesRejected                 Expense[]                    @relation("ExpenseRejectedBy")
  expensesPaid                     Expense[]                    @relation("ExpensePaidBy")
  expenseStatusChanges             ExpenseStatusHistory[]       @relation("ExpenseStatusChangedBy")
  expenseBudgetsCreated            ExpenseBudget[]              @relation("ExpenseBudgetCreatedBy")
  paymentsReconciled               Payment[]                    @relation("PaymentReconciledBy")
  bankAccountsCreated              BankAccount[]                @relation("BankAccountCreatedBy")
  bankTransactionsCreated          BankTransaction[]            @relation("BankTransactionCreatedBy")
  bankTransactionsReconciled       BankTransaction[]            @relation("BankTransactionReconciledBy")
  bankStatementsImported           BankStatementImport[]        @relation("BankStatementImportedBy")
  bankReconciliationsCreated       BankReconciliation[]         @relation("BankReconciliationCreatedBy")
  bankReconciliationsCompleted     BankReconciliation[]         @relation("BankReconciliationCompletedBy")
  bankReconciliationsReviewed      BankReconciliation[]         @relation("BankReconciliationReviewedBy")
  bankProfileOverridesCreated      BankProfileOverride[]        @relation("BankProfileCreatedBy")
  bankMatchingRulesCreated         BankMatchingRule[]           @relation("BankMatchingRuleCreatedBy")
  bankImportProfilesCreated        BankImportProfile[]          @relation("BankImportProfileCreatedBy")
  chartOfAccountsCreated           ChartOfAccount[]             @relation("CoaCreatedBy")
  fiscalPeriodsCreated             FiscalPeriod[]               @relation("FiscalPeriodCreatedBy")
  fiscalPeriodsClosed              FiscalPeriod[]               @relation("FiscalPeriodClosedBy")
  fiscalPeriodsLocked              FiscalPeriod[]               @relation("FiscalPeriodLockedBy")
  accountingJournalsCreated        AccountingJournal[]          @relation("AccountingJournalCreatedBy")
  journalEntriesCreated            JournalEntry[]               @relation("JournalEntryCreatedBy")
  journalEntriesValidated          JournalEntry[]               @relation("JournalEntryValidatedBy")
  journalEntryLinesLettered        JournalEntryLine[]           @relation("JournalEntryLineLetteredBy")
  taxDeclarationsCreated           TaxDeclaration[]             @relation("TaxDeclarationCreatedBy")
  taxDeclarationsSubmitted         TaxDeclaration[]             @relation("TaxDeclarationSubmittedBy")
  documentTemplatesCreated         DocumentTemplate[]           @relation("DocTemplateCreatedBy")
  documentTemplatesUpdated         DocumentTemplate[]           @relation("DocTemplateUpdatedBy")
  customFieldsCreated              CustomField[]                @relation("CustomFieldCreatedBy")
  workflowRulesCreated             WorkflowRule[]               @relation("WorkflowRuleCreatedBy")
  webhooksCreated                  Webhook[]                    @relation("WebhookCreatedBy")
  apiKeysCreated                   ApiKey[]                     @relation("ApiKeyCreatedBy")
  apiKeysRevoked                   ApiKey[]                     @relation("ApiKeyRevokedBy")
  ipWhitelistCreated               IpWhitelist[]                @relation("IpWhitelistCreatedBy")
  exportJobsCreated                ExportJob[]                  @relation("ExportJobCreatedBy")
  approvalWorkflowStepsAsApprover  ApprovalWorkflowStep[]       @relation("StepApprover")
  approvalRequestsCreated          ApprovalRequest[]            @relation("ApprovalRequester")
  approvalRequestsResolved         ApprovalRequest[]            @relation("ApprovalResolver")
  approvalDecisions                ApprovalDecision[]           @relation("ApprovalDecider")
  approvalDelegationsReceived      ApprovalDecision[]           @relation("ApprovalDelegate")

  emailTemplateVersions   EmailTemplateVersion[]
  emailTemplatesUpdated   EmailTemplate[]        @relation("EmailTemplateUpdatedBy")

  refreshTokens           RefreshToken[]
  loginHistory            LoginHistory[]
  passwordResetTokens     PasswordResetToken[]
  productCategories       ProductCategory[]
  products                Product[]
  clients                 Client[]
  proformasCreated        Proforma[]              @relation("ProformaCreatedBy")
  proformasAssigned       Proforma[]              @relation("ProformaAssignedTo")
  proformaStatusHistory   ProformaStatusHistory[]
  invoicesCreated         Invoice[]               @relation("InvoiceCreatedBy")
  invoicesAssigned        Invoice[]               @relation("InvoiceAssignedTo")
  invoicesCancelled       Invoice[]               @relation("InvoiceCancelledBy")
  invoiceStatusHistory    InvoiceStatusHistory[]
  payments                Payment[]
  recurringTemplates      RecurringInvoiceTemplate[]
  auditLogs               AuditLog[]
  backups                 Backup[]
  notifications           Notification[]
  notificationSettings    NotificationSetting[]

  @@map("users")
}

model RefreshToken {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique @map("token_hash") @db.VarChar(255)
  deviceName   String?   @map("device_name") @db.VarChar(255)
  deviceInfo   Json      @default("{}") @map("device_info")
  ipAddress    String?   @map("ip_address")
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz()
  revokeReason   String?   @map("revoke_reason") @db.VarChar(100)
  lastActivityAt DateTime  @default(now()) @map("last_activity_at") @db.Timestamptz()
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@map("refresh_tokens")
}

model LoginHistory {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email         String   @db.VarChar(255)
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  success       Boolean  @default(false)
  failureReason String?  @map("failure_reason") @db.VarChar(100)
