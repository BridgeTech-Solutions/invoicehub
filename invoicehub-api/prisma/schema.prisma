  isAutoApply   Boolean      @default(false) @map("is_auto_apply")
  createdById   String       @map("created_by") @db.Uuid
  createdBy     User         @relation("BankMatchingRuleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("bank_matching_rules")
}

model BankImportProfile {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                String    @db.VarChar(255)
  bankName            String?   @map("bank_name") @db.VarChar(255)
  country             String?   @db.VarChar(10)
  source              String    @default("user") @db.VarChar(20)
  fileFormat          String    @default("csv") @map("file_format") @db.VarChar(20)
  encoding            String    @default("utf-8") @db.VarChar(30)
  delimiter           String    @default(";") @db.VarChar(5)
  dateFormat          String    @default("DD/MM/YYYY") @map("date_format") @db.VarChar(30)
  numberFormat        Json      @map("number_format")
