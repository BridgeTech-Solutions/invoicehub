model ExpenseCategory {
  id                    String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                  String    @unique @db.VarChar(100)
  description           String?
  icon                  String?   @db.VarChar(50)
  color                 String?   @db.Char(7)
  sortOrder             Int       @default(0) @map("sort_order") @db.SmallInt
  isActive              Boolean   @default(true) @map("is_active")
  accountingAccount     String?   @map("accounting_account") @db.VarChar(20)
  accountingAccountLabel String?  @map("accounting_account_label") @db.VarChar(100)
  monthlyBudget         Decimal?  @map("monthly_budget") @db.Decimal(15, 2)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt             DateTime? @map("deleted_at") @db.Timestamptz()
  createdById           String?   @map("created_by") @db.Uuid
  createdBy             User?     @relation("ExpenseCategoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  expenses Expense[]
  budgets  ExpenseBudget[]

  @@map("expense_categories")
}

model Expense {
  id                    String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  number                String          @unique @db.VarChar(50)
  officeId              String          @map("office_id") @db.Uuid
  office                AgencyOffice    @relation(fields: [officeId], references: [id], onDelete: Restrict)
  categoryId            String          @map("category_id") @db.Uuid
  category              ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdById           String          @map("created_by") @db.Uuid
  createdBy             User            @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  submittedById         String?         @map("submitted_by") @db.Uuid
  submittedBy           User?           @relation("ExpenseSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  approvedById          String?         @map("approved_by") @db.Uuid
  approvedBy            User?           @relation("ExpenseApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectedById          String?         @map("rejected_by") @db.Uuid
  rejectedBy            User?           @relation("ExpenseRejectedBy", fields: [rejectedById], references: [id], onDelete: SetNull)
  paidById              String?         @map("paid_by") @db.Uuid
  paidBy                User?           @relation("ExpensePaidBy", fields: [paidById], references: [id], onDelete: SetNull)
  beneficiaryName       String?         @map("beneficiary_name") @db.VarChar(255)
  supplierId            String?         @map("supplier_id") @db.Uuid
  supplier              Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  expenseDate           DateTime        @default(dbgenerated("CURRENT_DATE")) @map("expense_date") @db.Date
  submittedAt           DateTime?       @map("submitted_at") @db.Timestamptz()
  approvedAt            DateTime?       @map("approved_at") @db.Timestamptz()
  rejectedAt            DateTime?       @map("rejected_at") @db.Timestamptz()
  paidAt                DateTime?       @map("paid_at") @db.Timestamptz()
  dueDate               DateTime?       @map("due_date") @db.Date
  title                 String          @db.VarChar(500)
  description           String?
  amountHt              Decimal         @default(0) @map("amount_ht") @db.Decimal(15, 2)
  taxRate               Decimal         @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount             Decimal         @default(0) @map("tax_amount") @db.Decimal(15, 2)
  amountTtc             Decimal         @default(0) @map("amount_ttc") @db.Decimal(15, 2)
  paymentMethod         PaymentMethod?  @map("payment_method")
  paidAmount            Decimal         @default(0) @map("paid_amount") @db.Decimal(15, 2)
  bankAccountId         String?         @map("bank_account_id") @db.Uuid
  bankTransactionId     String?         @map("bank_transaction_id") @db.Uuid
  reference             String?         @db.VarChar(255)
  isRecurring           Boolean         @default(false) @map("is_recurring")
  frequency             ExpenseFrequency?
  nextOccurrenceDate    DateTime?       @map("next_occurrence_date") @db.Date
  endDate               DateTime?       @map("end_date") @db.Date
  parentExpenseId       String?         @map("parent_expense_id") @db.Uuid
  parentExpense         Expense?        @relation("ExpenseRecurring", fields: [parentExpenseId], references: [id], onDelete: SetNull)
  childExpenses         Expense[]       @relation("ExpenseRecurring")
  isEmployeeExpense     Boolean         @default(false) @map("is_employee_expense")
  reimbursedAt          DateTime?       @map("reimbursed_at") @db.Timestamptz()
  reimbursementReference String?        @map("reimbursement_reference") @db.VarChar(255)
  status                ExpenseStatus   @default(draft)
  rejectionReason       String?         @map("rejection_reason")
  accountingAccount     String?         @map("accounting_account") @db.VarChar(20)
  attachmentPaths       String[]        @default([]) @map("attachment_paths")
  metadata              Json            @default("{}")
  createdAt             DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt             DateTime?       @map("deleted_at") @db.Timestamptz()

  requiresApproval    Boolean  @default(false) @map("requires_approval_wf")
  approvalRequestId   String?  @map("approval_request_id") @db.Uuid

  statusHistory ExpenseStatusHistory[]

  @@map("expenses")
}

model ExpenseStatusHistory {
  id             String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  expenseId      String         @map("expense_id") @db.Uuid
  expense        Expense        @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  changedById    String         @map("changed_by") @db.Uuid
  changedBy      User           @relation("ExpenseStatusChangedBy", fields: [changedById], references: [id], onDelete: Restrict)
  previousStatus ExpenseStatus? @map("previous_status")
  newStatus      ExpenseStatus  @map("new_status")
  reason         String?
  changedAt      DateTime       @default(now()) @map("changed_at") @db.Timestamptz()

  @@map("expense_status_history")
}

model ExpenseBudget {
  id            String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  categoryId    String          @map("category_id") @db.Uuid
  category      ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  year          Int             @db.SmallInt
  month         Int?            @db.SmallInt
  budgetAmount  Decimal         @map("budget_amount") @db.Decimal(15, 2)
  notes         String?
  createdById   String?         @map("created_by") @db.Uuid
  createdBy     User?           @relation("ExpenseBudgetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([categoryId, year, month])
  @@map("expense_budgets")
}

